# Clerk Authentication (frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk Authentication (backend)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://operblock:operblock@localhost:5432/operblock

# App
APP_URL=http://localhost:5173
PORT=3001
NODE_ENV=development

# Production (Render/Railway): set NODE_ENV=production
# APP_URL=https://your-app.onrender.com  OR  https://your-app.up.railway.app
# VITE_CLERK_PUBLISHABLE_KEY must be set at build time on the host
# PORT is set automatically by Render/Railway — leave unset in production
