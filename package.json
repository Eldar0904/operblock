{
  "name": "operblock",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "setup:check": "tsx scripts/check-setup.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.7",
    "@clerk/clerk-react": "^5.22.0",
    "@clerk/express": "^2.1.43",
    "@clerk/localizations": "^4.13.5",
    "@tanstack/react-query": "^5.62.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "i18next": "^26.3.6",
    "lucide-react": "^0.469.0",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.7.2",
    "vite": "^6.0.0"
  }
}
